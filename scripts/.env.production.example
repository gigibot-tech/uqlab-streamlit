# OpenShift Deployment Configuration
# Copy this file to .env.production and fill in your values
# See scripts/README.md for detailed documentation

#############################################
# REQUIRED VARIABLES
#############################################

# Application Identity
# Must be lowercase, alphanumeric, and hyphens only
APP_NAME=my-app
PROJECT_NAME=my-openshift-project

# Environment
ENVIRONMENT=production

# Git Repository
# Must be SSH format: git@github.com:user/repo.git
GIT_SSH_URL=git@github.com:username/repository.git

# Admin User Configuration
# Email must be valid format
# Password must be at least 8 characters
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# User Signup Password (optional - leave empty to disable signup)
# If set, must be at least 8 characters
SIGNUP_ACCESS_PASSWORD=changethis

# API Security
# Must be 16, 32, or 64 characters (power of 2)
API_KEY=changethis

# Backend Secret Key
# Must be at least 8 characters (auto-generated if missing)
SECRET_KEY=changethis

#############################################
# DATABASE CONFIGURATION
#############################################

# PostgreSQL Configuration
POSTGRES_SERVER=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
# Password must be at least 8 characters
POSTGRES_PASSWORD=changethis

#############################################
# OPTIONAL VARIABLES
#############################################

# GitHub Integration (Optional but Recommended)
# Personal Access Token for automatic webhook creation and deploy key management
# Without this token, you'll need to manually add deploy keys and webhooks to GitHub

# GitHub Host Configuration
# Set the GitHub instance you're using
# - For IBM GitHub Enterprise: github.ibm.com (default)
# - For Public GitHub: github.com
# - For other GitHub Enterprise instances: your-github-enterprise-domain.com
GITHUB_HOST=github.ibm.com

# GitHub Personal Access Token
# How to create a GitHub Personal Access Token:
# For IBM GitHub Enterprise:
#   1. Go to https://github.ibm.com/settings/tokens
# For Public GitHub:
#   1. Go to https://github.com/settings/tokens
#
# Then:
# 2. Click "Generate new token (classic)"
# 3. Give it a descriptive name (e.g., "OpenShift Deployment")
# 4. Select the following scopes:
#    - repo (Full control of private repositories)
#    - admin:repo_hook (Full control of repository hooks)
# 5. Click "Generate token" and copy the token
# 6. Paste it here (starts with ghp_)
#
# Required permissions: repo, admin:repo_hook
# Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Used to add SSH DEPLOY KEY to repository automatically and add WEBHOOKS to the repo directly.
# GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Backend CORS Origins (Optional)
# Auto-generated from frontend URL if not provided
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,https://localhost,https://localhost:5173,https://localhost:5174"

# Webhook Branch Filter (Optional)
# If set, OpenShift webhooks will only trigger builds when the specified branch is updated
# This is useful for production deployments where you only want to build from main/master branch
# Leave empty or comment out to trigger builds on all branches
# Examples: main, master, production, develop
# WEBHOOK_BRANCH_FILTER=main

#############################################
# FRONTEND ENVIRONMENT VARIABLES
#############################################

# All variables prefixed with VITE_ are automatically injected into the frontend build
# VITE_API_URL is automatically set to the backend URL

# Example custom frontend variables:
# VITE_CUSTOM_FEATURE=enabled
# VITE_ANALYTICS_ID=UA-123456-1
# VITE_APP_VERSION=1.0.0
# VITE_DEBUG_MODE=false

#############################################
# CUSTOM APPLICATION VARIABLES
#############################################

# Add any custom variables your application needs here
# They will be automatically added to the OpenShift secret

# Example:
# CUSTOM_SERVICE_URL=https://api.example.com
# CUSTOM_API_KEY=your-api-key
# FEATURE_FLAG_NEW_UI=true

#############################################
# OAUTH2 PROXY CONFIGURATION (OPTIONAL)
#############################################

# OAuth2 Proxy Settings
# If any OAuth variable is set, ALL must be configured
# Leave all commented/empty to disable OAuth authentication

# OAuth2 Proxy Cookie Domain
# Example: localhost:4180 (for local), your-app.example.com (for production)
# OAUTH2_PROXY_COOKIE_DOMAIN=localhost:4180

# OAuth2 Proxy Cookie Secret
# Must be at least 16 characters (recommended: 32)
# Generate with: openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
# OAUTH2_PROXY_COOKIE_SECRET=asdfasdfasdfasdf

# OAuth2 Proxy Client ID
# Obtained from your OIDC provider
# OAUTH2_PROXY_CLIENT_ID=<client_id>

# OAuth2 Proxy Client Secret
# Obtained from your OIDC provider
# OAUTH2_PROXY_CLIENT_SECRET=<client_secret>

# OAuth2 Proxy OIDC Issuer URL
# Example: https://accounts.google.com, https://login.microsoftonline.com/tenant-id/v2.0
# OAUTH2_PROXY_OIDC_ISSUER_URL=<oidc_issuer_url>

# OAuth2 Proxy Redirect URL
# Must match the callback URL registered with your OIDC provider
# Example: http://localhost:4180/oauth2/callback
# OAUTH2_PROXY_REDIRECT_URL=http://localhost:4180/oauth2/callback

# OAuth2 Proxy Well-Known URL (Optional)
# Auto-discovered from OIDC_ISSUER_URL if not provided
# OAUTH2_PROXY_WELL_KNOWN_URL=<well_known_url>

#############################################
# PLAYWRIGHT TEST CONFIGURATION (OPTIONAL)
#############################################

# Playwright Test User Credentials
# Used for automated testing with OAuth enabled
# PLAYWRIGHT_TEST_USER_EMAIL=playwright@email.com
# PLAYWRIGHT_TEST_USER_PASSWORD=playwright
