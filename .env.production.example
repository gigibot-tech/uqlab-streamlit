# See scripts/README.md for detailed documentation

# Application Identity
APP_NAME=my-app
PROJECT_NAME=my-openshift-project
ENVIRONMENT=production

# Git Repository
GIT_SSH_URL=git@github.com:username/repository.git

# Admin User
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
SIGNUP_ACCESS_PASSWORD=changethis

# Security
SECRET_KEY=changethis

# Database
POSTGRES_SERVER=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# GitHub Integration (Optional)
GITHUB_HOST=github.ibm.com

# Deployment (Optional)
DEPLOYMENT_BRANCH_FILTER=
BACKEND_CORS_ORIGINS=

# OAuth2 Proxy (Optional - All required if any is set)
OAUTH2_PROXY_COOKIE_SECRET=asdfasdfasdfasdf
OAUTH2_PROXY_CLIENT_ID=<client_id>
OAUTH2_PROXY_CLIENT_SECRET=<client_secret>
OAUTH2_PROXY_OIDC_ISSUER_URL=<oidc_issuer_url>
